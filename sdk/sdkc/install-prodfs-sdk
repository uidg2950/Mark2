# Verification of Parameter's number
# Expected: workspace path & size of images.

help_info() {
    cat << HELP
./$(basename "$0") --workspace /path/to/workspace [--image_size 4K] [ --signed_images /path/to/cont-signed-images.tar ] [--build_version secret_version]
Script for manual testing of esim.

Options:
    -h|--help                   Display this information.
    -w|--workspace              Workspace directory.
    -i|--image_size             Image size. Default - 4K
    -b|--build_version          Build version.
    -s|--signed_images          Path to conti-signed-images for OTC generated build. By default empty
    -ta|--trusted_app           Name (without extention) and path to custom TA to be signed --trustep_app appname appdir

HELP
}


process_cli_parameters() {
    # Verify the shell is set to bash
    if [[ ! $(readlink "$(which sh)") =~ bash ]]; then
      echo ""
      echo "### ERROR: Please Change your /bin/sh symlink to point to bash. ### "
      echo "### sudo ln -sf /bin/bash /bin/sh ### "
      echo ""
      exit 1
    fi

    if [ $# -eq 0 ]; then
        help_info
        exit 1
    fi

    while [ $# -gt 0 ]; do
        param="$1"
        shift
        case $param in
            -h|--help)
                help_info
                exit 0
                ;;
            -w|--workspace)
                WORKSPACE="$1"
                shift
                ;;
            -i|--image_size)
                SIZE_IMG="$1"
                shift
                ;;
            -b|--build_version)
                BLD_VER="$1"
                shift
                ;;
            -s|--signed_images)
                OTC_PATH="$1"
                shift
                ;;
            -ta|--trusted_app)
                TA_NAME="$1"
                TA_PATH="$2"
                shift
                shift
                ;;
            *)
                echo "Invalid parameter: $param.\nUse -h|--help for more information."
                exit 1
                ;;
        esac
    done

    if [[ -z ${WORKSPACE} ]]; then
       echo "ERROR: Workspace not provided"
       exit 1
    fi
}


process_cli_parameters "$@"

# Manifest file
file_manifest="file_manifest.csv"

# Size of Images
if [[ ! -z  "${OTC_PATH}" ]]; then
    echo "Path to conti-singed images provided. Attempt to copy files into workspace"
    echo "cp ${OTC_PATH} ${WORKSPACE}"
    cp ${OTC_PATH} ${WORKSPACE}

    [[ "$?" != 0 ]] && echo "Failed to copy ${OTC_PATH}. Abort execution" && exit 1
else
    echo "OTC_Path not provided. Proceed to regular generation".
fi

# Size of Images
if [[ -z  "${SIZE_IMG}" ]]; then
    SIZE_IMG="4K"
    echo "${SIZE_IMG} images will be generated by default"
fi
# Verification of valid sizes
if [[ ! "${SIZE_IMG}" =~ ^(2|4)K$ ]] && [[ ! "${SIZE_IMG}" == "all" ]]; then
    echo "${SIZE_IMG} is not a valid size of image" && exit 1
fi

export CAS_WORKDIR="${WORKSPACE}"

# Overwriting bld_version_number
if [[ -n "${BLD_VER}" ]];then
    [[ ! -f "${CAS_WORKDIR}/.build/env-buildsys-static" ]] && exit 1
    sed -i "s/bld_version_number=.*/bld_version_number=${BLD_VER}/g" "${CAS_WORKDIR}/.build/env-buildsys-static"
    echo "bld_version_number updated to ${BLD_VER}"
fi

# Source Files for environment.
source_files=(
    '.repo/manifests/env-plf-config'
    '.build/env-common'
    '.build/env-buildsys-static'
)

echo "Import external libraries"
for sfile in "${source_files[@]}"; do
    sfile_path="${CAS_WORKDIR}/${sfile}"
    [ ! -f $sfile_path ] && echo "Unable to locate ${sfile_path}" && exit 1
    echo "source ${sfile_path}"; source $sfile_path
done

# Imported variables
TARGETFS_DIRS=(${CAS_TARGETFS} ${CAS_TOOLCHAINFS})
TARGETFS_SCRIPT="target-fsdir"

# Checking if something was removed...
[ -f "${CAS_TARGETFS}/${file_manifest}.orig" ] && echo "Warning: The original list of files to be installed was modified"

# Backup previous log files
SUMMARY_FILES=$(ls -al ${CAS_WORKDIR}/logs/ | grep summary* | wc -l)
if  [[ "${SUMMARY_FILES}" -ge 1 ]]; then
    SUMMARY=$(ls -a ${CAS_WORKDIR}/logs/ | grep summary.log)
    mv "${CAS_WORKDIR}/logs/${SUMMARY}" "${CAS_WORKDIR}/logs/summary_${SUMMARY_FILES}.log"
fi

# Targetfs directory will be created for the image creation.
echo "Creating targetfs dir"
for targetfs in "${TARGETFS_DIRS[@]}";do
    [ ! -f "${targetfs}/${TARGETFS_SCRIPT}" ] && echo "Unable to locate ${targetfs}/${TARGETFS_SCRIPT}" && continue
    pushd ${targetfs} &>/dev/null
        target_flavor=$(echo "${targetfs}" | rev | cut -d"/" -f3 | rev )
        echo "targetfs for ${target_flavor}"
        bash ${targetfs}/${TARGETFS_SCRIPT} || exit $?
    popd
done


#Setup singing environmetn for custom TA
if [[ ! -z "${TA_NAME}" ]]; then
    echo "TA provided ${TA_PATH}"
    export CUST_APP_TA_DIR="${TA_PATH}"
    export CUST_APP_TA_NAME="${TA_NAME}"
    ${bld_script_dir}/set-cust-ta-sign-env ${TA_NAME} ${TA_PATH} 1
fi

# Launching install-prodfs
INSTALL_PRODFS_FILE="${bld_script_dir}/install-prodfs"
[ ! -f $INSTALL_PRODFS_FILE ] && echo "Unable to locate ${INSTALL_PRODFS_FILE}" && exit 1
echo "bash ${INSTALL_PRODFS_FILE} all ${SIZE_IMG} all fix_fs_structure"
bash $INSTALL_PRODFS_FILE "all" "${SIZE_IMG}" "all" "fix_fs_structure"  || exit $?

#cleanup sing environment
if [[ ! -z "${TA_NAME}" ]]; then
    echo "TA provided ${TA_PATH}"
    ${bld_script_dir}/set-cust-ta-sign-env ${TA_NAME} ${TA_PATH} 0
fi

# Output Logs
OUTPUT_LOG=$(ls -a ${CAS_WORKDIR}/logs/ | grep .summary.log)
if [[ ! -z ${OUTPUT_LOG} ]]; then
    OUTPUT_LOG=$(ls ${CAS_WORKDIR}/logs/.summary.log)
    mv ${OUTPUT_LOG} ${CAS_WORKDIR}/logs/summary.log
    echo "Change log file: ${WORKSPACE}/logs/summary.log"
fi
echo "Change log file: ${WORKSPACE}/logs/summary.log"
